# Copy to .env for local dev (DO NOT commit .env)
PORT=8080
PGHOST=your-shared-postgres.postgres.database.azure.com
PGPORT=5432
PGDATABASE=battle_bots
PGUSER=your_user@your-shared-postgres
PGPASSWORD=replace_me
PGSSL=true
ALLOWED_ORIGINS=http://localhost:9091,https://YOUR_USERNAME.github.io
TICK_HZ=60
BROADCAST_HZ=30
ROUND_SECONDS=60
ROUNDS_TO_WIN=2
COIN_WIN=50
COIN_LOSS=10
# Optional Google OAuth (placeholder for v2)
GOOGLE_CLIENT_ID=
