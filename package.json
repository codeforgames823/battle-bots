{
  "name": "battle-bots",
  "version": "0.1.0",
  "description": "Real-time online 2-player flip-the-other-bot browser game",
  "private": true,
  "type": "module",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "node --watch server/server.js",
    "init-db": "node server/init-db.js",
    "serve:static": "python -m http.server 9091",
    "gen:art": "node scripts/generate-art.js"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "pg": "^8.13.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "sharp": "^0.33.5"
  }
}
